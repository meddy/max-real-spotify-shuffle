{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["react", "react-hooks", "typescript"],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "warn"
  },
  "ignorePatterns": ["dist/**", "coverage/**", "node_modules/**"],
  "rules": {
    "eslint/no-await-in-loop": "off",
    "react/react-in-jsx-scope": "off"
  }
}
