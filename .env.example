VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_SPOTIFY_CLIENT_ID=
# Spotify redirect URI is window.location.origin at runtime (one build for dev + prod).
# Register each origin in the Spotify app (e.g. http://127.0.0.1:5173 and https://<project>.web.app).
# Optional only for non-browser tooling: VITE_SPOTIFY_REDIRECT_URI=
VITE_ALLOWLIST_EMAILS=you@example.com
